{
  "env": {
    "FORCE_HYPERLINK": "1",
    "EDITOR": "vim",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "attribution": {
    "commit": "",
    "pr": "",
    "sessionUrl": false
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Bash(git *)"
    ],
    "deny": [
      "Read(**/*credentials*)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/scripts/statusline.sh"
  },
  "footerLinksRegexes": [
    {
      "type": "regex",
      "pattern": "CVE-(?<cve>\\d{4}-\\d+)",
      "url": "https://nvd.nist.gov/vuln/detail/CVE-{cve}",
      "label": "CVE-{cve}"
    }
  ],
  "subagentStatusLine": {
    "type": "command",
    "command": "bash ~/.claude/scripts/subagent-statusline.sh"
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "slidev@slidev-dev-marketplace": true,
    "extending-your-agent-tutorial@extending-your-agent": true,
    "figlet-text-converter@skillsforge-marketplace": true,
    "yoink@yoink-marketplace": true,
    "marketing-skills@marketingskills": true
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "slidev-dev-marketplace": { "source": { "source": "github", "repo": "rhuss/cc-slidev" } },
    "extending-your-agent": { "source": { "source": "directory", "path": "/mnt/c/Users/woute/Dropbox/Personal/Programming/UnixCode/courses/2026-07-01-Extending-Your-Agent" } },
    "skillsforge-marketplace": { "source": { "source": "github", "repo": "rawveg/skillsforge-marketplace" } },
    "yoink-marketplace": { "source": { "source": "github", "repo": "itenium-be/Yoink" } },
    "marketingskills": { "source": { "source": "github", "repo": "coreyhaines31/marketingskills" } }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Itenium-ing", "Over-engineering", "Bikeshedding", "Summoning Skynet",
      "Reticulating splines", "Blaming the intern", "Consulting the rubber duck"
    ]
  },
  "spinnerTipsOverride": {
    "tips": [
      "💡 itenium tip: the description IS the interface"
    ]
  },
  "alwaysThinkingEnabled": true,
  "fastMode": false,
  "companyAnnouncements": [
    "itenium AI Extending your Agent, like a champ"
  ],
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": false,
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "editorMode": "normal",
  "autoCompactEnabled": false,
  "fileCheckpointingEnabled": true,
  "skipAutoPermissionPrompt": true
}
